{
  "name": "amenti",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "fsq:import": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/import-foursquare.ts",
    "fsq:process": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/process-foursquare-backlog.ts",
    "leads:fetch": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/fetch-leads.ts",
    "pestworld": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/fetch-pestworld.ts",
    "leads:findsite": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/find-missing-websites.ts",
    "campaigns:seed-default": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/seed-default-campaign.ts",
    "dedupe:domains": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/archive-domain-dupes.ts",
    "dry-run-fields": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config scripts/dry-run-fields.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.1.0",
    "@types/topojson-client": "^3.1.5",
    "@vercel/blob": "^2.3.3",
    "cheerio": "^1.0.0",
    "clsx": "^2.1.1",
    "d3-scale": "^4.0.2",
    "lucide-react": "^0.469.0",
    "next": "^16.2.4",
    "playwright": "^1.59.1",
    "prop-types": "^15.8.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-simple-maps": "^3.0.0",
    "resend": "^6.12.0",
    "tailwind-merge": "^2.6.0",
    "topojson-client": "^3.1.0",
    "us-atlas": "^3.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/d3-scale": "^4.0.9",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/react-simple-maps": "^3.0.6",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.10",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "d3-color": "^3.1.0",
    "postcss": "^8.5.10",
    "uuid": "^14.0.0"
  }
}
